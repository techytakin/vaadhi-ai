<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>VaadhiAI — Your Legal Advocate, Powered by AI</title>
  <meta name="description" content="Free AI-powered Indian legal assistant. Ask legal questions in Tamil, Telugu, Hindi, English. Instant answers based on Indian law."/>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,400&family=Outfit:wght@300;400;500;600&display=swap" rel="stylesheet"/>
  <style>
    :root {
      --ink:      #0D1117;
      --ink2:     #1C2333;
      --ink3:     #2D3748;
      --crimson:  #C0392B;
      --crimson2: #E74C3C;
      --gold:     #D4A017;
      --gold2:    #F0C040;
      --cream:    #FAF7F2;
      --cream2:   #F0EBE1;
      --muted:    #8892A4;
      --white:    #FFFFFF;
      --radius:   12px;
      --shadow:   0 2px 16px rgba(0,0,0,0.18);
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background: var(--ink);
      color: var(--cream);
      font-family: 'Outfit', sans-serif;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      position: relative;
      overflow-x: hidden;
    }

    /* Subtle background texture */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image:
        radial-gradient(ellipse 80% 50% at 20% 20%, rgba(192,57,43,0.06) 0%, transparent 60%),
        radial-gradient(ellipse 60% 40% at 80% 80%, rgba(212,160,23,0.05) 0%, transparent 60%);
      pointer-events: none;
      z-index: 0;
    }

    /* ── HEADER ── */
    header {
      position: sticky;
      top: 0;
      z-index: 200;
      background: rgba(13,17,23,0.92);
      backdrop-filter: blur(16px);
      border-bottom: 1px solid rgba(255,255,255,0.06);
      padding: 0 24px;
      height: 58px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
    }

    .logo {
      display: flex;
      align-items: center;
      gap: 11px;
      text-decoration: none;
      flex-shrink: 0;
    }
    .logo-mark {
      width: 34px;
      height: 34px;
      background: var(--crimson);
      border-radius: 9px;
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
      overflow: hidden;
    }
    .logo-mark::after {
      content: '';
      position: absolute;
      bottom: -4px;
      right: -4px;
      width: 18px;
      height: 18px;
      background: var(--gold);
      border-radius: 50%;
      opacity: 0.5;
    }
    .logo-mark svg { width: 18px; height: 18px; fill: white; position: relative; z-index: 1; }
    .logo-wordmark { font-family: 'Playfair Display', serif; font-size: 20px; font-weight: 700; color: var(--cream); letter-spacing: -0.3px; }
    .logo-wordmark span { color: var(--gold); }

    .header-right { display: flex; align-items: center; gap: 10px; }

    .lang-group { display: flex; gap: 4px; }
    .lang-btn {
      padding: 5px 11px;
      border-radius: 20px;
      border: 1px solid rgba(255,255,255,0.12);
      background: transparent;
      color: var(--muted);
      font-size: 12px;
      font-weight: 400;
      font-family: 'Outfit', sans-serif;
      cursor: pointer;
      transition: all 0.18s;
      white-space: nowrap;
    }
    .lang-btn:hover { color: var(--cream); border-color: rgba(255,255,255,0.3); }
    .lang-btn.active {
      background: var(--crimson);
      border-color: var(--crimson);
      color: white;
      font-weight: 500;
    }

    /* ── HERO ── */
    #hero {
      position: relative;
      z-index: 1;
      text-align: center;
      padding: 52px 24px 32px;
      max-width: 680px;
      margin: 0 auto;
      width: 100%;
      animation: heroIn 0.6s ease both;
    }
    @keyframes heroIn {
      from { opacity: 0; transform: translateY(18px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    .hero-pill {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background: rgba(192,57,43,0.12);
      border: 1px solid rgba(192,57,43,0.25);
      color: #E88A80;
      font-size: 12px;
      font-weight: 500;
      padding: 5px 14px;
      border-radius: 20px;
      margin-bottom: 20px;
      letter-spacing: 0.03em;
    }
    .hero-pill::before { content: '●'; font-size: 8px; color: var(--crimson2); }

    .hero-title {
      font-family: 'Playfair Display', serif;
      font-size: clamp(30px, 5.5vw, 48px);
      font-weight: 700;
      line-height: 1.18;
      letter-spacing: -0.5px;
      margin-bottom: 14px;
      color: var(--cream);
    }
    .hero-title em {
      font-style: italic;
      color: var(--gold);
    }

    .hero-sub {
      font-size: 15px;
      color: var(--muted);
      line-height: 1.65;
      max-width: 460px;
      margin: 0 auto 32px;
    }

    /* ── TOPIC CARDS ── */
    .topics-wrap {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 10px;
      margin-bottom: 36px;
      animation: heroIn 0.6s 0.1s ease both;
    }
    .topic-card {
      background: var(--ink2);
      border: 1px solid rgba(255,255,255,0.06);
      border-radius: var(--radius);
      padding: 14px 12px;
      cursor: pointer;
      transition: all 0.2s;
      text-align: left;
    }
    .topic-card:hover {
      background: rgba(192,57,43,0.1);
      border-color: rgba(192,57,43,0.35);
      transform: translateY(-2px);
    }
    .topic-icon { font-size: 20px; margin-bottom: 7px; line-height: 1; }
    .topic-title { font-size: 13px; font-weight: 500; color: var(--cream); margin-bottom: 2px; }
    .topic-desc { font-size: 11px; color: var(--muted); line-height: 1.4; }

    /* ── CHAT ── */
    #chat-section {
      flex: 1;
      display: flex;
      flex-direction: column;
      max-width: 720px;
      width: 100%;
      margin: 0 auto;
      padding: 0 16px;
      position: relative;
      z-index: 1;
    }

    #chat-log {
      flex: 1;
      display: flex;
      flex-direction: column;
      gap: 18px;
      padding: 4px 0 16px;
    }

    .msg-row {
      display: flex;
      gap: 10px;
      animation: msgIn 0.28s ease both;
    }
    @keyframes msgIn {
      from { opacity: 0; transform: translateY(8px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .msg-row.user { flex-direction: row-reverse; }

    .msg-avatar {
      width: 32px;
      height: 32px;
      border-radius: 9px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 14px;
      flex-shrink: 0;
      margin-top: 2px;
    }
    .msg-avatar.ai   { background: var(--crimson); }
    .msg-avatar.user { background: var(--ink3); border: 1px solid rgba(255,255,255,0.1); }

    .msg-bubble {
      max-width: 74%;
      padding: 13px 16px;
      border-radius: var(--radius);
      font-size: 14px;
      line-height: 1.72;
    }
    .msg-bubble.ai {
      background: var(--ink2);
      border: 1px solid rgba(255,255,255,0.07);
      border-top-left-radius: 3px;
      color: var(--cream);
    }
    .msg-bubble.ai strong { color: var(--gold2); font-weight: 500; }
    .msg-bubble.user {
      background: var(--crimson);
      color: white;
      border-top-right-radius: 3px;
    }
    .msg-disclaimer {
      margin-top: 10px;
      padding-top: 10px;
      border-top: 1px solid rgba(255,255,255,0.07);
      font-size: 11px;
      color: var(--muted);
      font-style: italic;
    }

    /* Typing dots */
    .typing-dots { display: flex; gap: 5px; align-items: center; padding: 4px 0; }
    .typing-dots span {
      width: 7px; height: 7px;
      background: var(--muted);
      border-radius: 50%;
      animation: dot 1.3s ease-in-out infinite;
    }
    .typing-dots span:nth-child(2) { animation-delay: 0.18s; }
    .typing-dots span:nth-child(3) { animation-delay: 0.36s; }
    @keyframes dot {
      0%,60%,100% { transform: translateY(0); opacity: 0.5; }
      30% { transform: translateY(-5px); opacity: 1; }
    }

    /* ── INPUT BAR ── */
    .input-zone {
      position: sticky;
      bottom: 0;
      z-index: 100;
      padding: 12px 0 20px;
      background: linear-gradient(to top, var(--ink) 60%, transparent);
    }
    .input-box {
      display: flex;
      align-items: flex-end;
      gap: 8px;
      background: var(--ink2);
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 16px;
      padding: 10px 10px 10px 18px;
      transition: border-color 0.2s;
    }
    .input-box:focus-within {
      border-color: rgba(192,57,43,0.5);
      box-shadow: 0 0 0 3px rgba(192,57,43,0.08);
    }
    #msg-input {
      flex: 1;
      background: transparent;
      border: none;
      outline: none;
      color: var(--cream);
      font-size: 14px;
      font-family: 'Outfit', sans-serif;
      resize: none;
      line-height: 1.55;
      max-height: 130px;
      overflow-y: auto;
      padding: 0;
    }
    #msg-input::placeholder { color: var(--muted); }

    .send-btn {
      width: 38px;
      height: 38px;
      background: var(--crimson);
      border: none;
      border-radius: 10px;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      transition: all 0.18s;
    }
    .send-btn:hover:not(:disabled) { background: var(--crimson2); transform: scale(1.06); }
    .send-btn:disabled { background: rgba(192,57,43,0.3); cursor: not-allowed; transform: none; }
    .send-btn svg { width: 15px; height: 15px; fill: white; }

    .input-hint {
      text-align: center;
      font-size: 11px;
      color: rgba(136,146,164,0.6);
      margin-top: 8px;
    }

    /* ── DIVIDER ── */
    .gold-line {
      width: 48px;
      height: 2px;
      background: var(--gold);
      border-radius: 2px;
      margin: 0 auto 14px;
      opacity: 0.5;
    }

    /* ── MOBILE ── */
    @media (max-width: 540px) {
      header { padding: 0 12px; }
      .logo-wordmark { font-size: 17px; }
      .lang-btn { font-size: 11px; padding: 4px 8px; }
      #hero { padding: 36px 16px 24px; }
      .topics-wrap { grid-template-columns: repeat(2, 1fr); }
      .msg-bubble { max-width: 86%; font-size: 13.5px; }
    }
  </style>
</head>
